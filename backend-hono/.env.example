# Backend environment example (do not commit secrets)

# OpenClaw Gateway (Clawdbot) — set port to match deployed OpenClaw (e.g. 7787)
OPENCLAW_BASE_URL=http://localhost:7787
OPENCLAW_API_KEY=
AI_PRIMARY_PROVIDER=openclaw

# Database
DATABASE_URL=

# Boardroom schedule (derived from OpenClaw cron)
# Example: every weekday at 10:00 ET
OPENCLAW_BOARDROOM_CRON=0 10 * * 1-5
OPENCLAW_BOARDROOM_TZ=America/New_York
BOARDROOM_MEETING_WINDOW_MINUTES=90

