# Backend environment example (do not commit secrets)

# OpenRouter — Primary AI provider (Claude Opus 4.6)
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
AI_PRIMARY_PROVIDER=openrouter
AI_DEFAULT_MODEL=openrouter-opus

# OpenRouter app metadata (shown in OpenRouter dashboard)
OPENROUTER_APP_URL=https://pulse-solvys.vercel.app
OPENROUTER_APP_NAME=Pulse-PIC-Gateway

# FMP API (Financial Modeling Prep — for IV scoring and market data)
FMP_API_KEY=

# Notion Integration
NOTION_API_KEY=

# GitHub OAuth (for GitHub Models — GPT-4o fallback)
# Create an OAuth app at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback

# Database
DATABASE_URL=

# Boardroom schedule
BOARDROOM_MEETING_WINDOW_MINUTES=90
