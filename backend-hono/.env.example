# Backend environment example (do not commit secrets)

# OpenRouter (Nous subscription) — Claude Opus 4.6 default inference
OPENROUTER_API_KEY=
OPENROUTER_APP_URL=https://pulse-solvys.vercel.app
OPENROUTER_APP_NAME=Pulse-AI-Gateway

# Optional: override base URL (default https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api

# AI default model (default: openrouter-opus = Claude Opus 4.6)
# AI_DEFAULT_MODEL=openrouter-opus
# AI_PRIMARY_PROVIDER=openrouter

# Hermes Agent CLI (optional — for gateway process if used)
# HERMES_BINARY_PATH=hermes

# GitHub OAuth (for GitHub Models fallback)
# Create an OAuth app at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback

# Database
DATABASE_URL=

# Boardroom schedule (Hermes cron)
# Example: every weekday at 10:00 ET
HERMES_BOARDROOM_CRON=0 10 * * 1-5
HERMES_BOARDROOM_TZ=America/New_York
BOARDROOM_MEETING_WINDOW_MINUTES=90

# Hyperliquid DEX (perpetual futures on Arbitrum)
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_VAULT_ADDRESS=
HYPERLIQUID_TESTNET=false
